{
  "name": "composio-cli",
  "version": "0.1.0",
  "description": "Agent-first TypeScript CLI for Composio toolkits.",
  "type": "module",
  "bin": {
    "composio-cli": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "pnpm typecheck && pnpm test"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@composio/core": "^0.6.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}

